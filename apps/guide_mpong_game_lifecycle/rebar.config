{erl_opts, [debug_info]}.

%% VERTICAL SLICING: each kept desk directory is an explicit src_dir.
%% Domain (event-sourced): host/join/start/end + engine + champion.
%% Integration (pong-over-mesh): advertise/broadcast + the matchmaking
%% coordinator (discover_games) + the seat emitters (request_seat,
%% reserve_seat) + the challenger paddle loop (play_remote_paddle).
{src_dirs, [
    "src",
    "src/host_game",
    "src/join_game",
    "src/start_game",
    "src/end_game",
    "src/run_game_engine",
    "src/broadcast_game_state",
    "src/advertise_game",
    "src/register_champion",
    "src/discover_games",
    "src/request_seat",
    "src/reserve_seat",
    "src/play_remote_paddle"
]}.

{shell, [{apps, [guide_mpong_game_lifecycle]}]}.
