[
    {hecate_mpong_bot, [
        {http_port, 8470},
        {data_dir,  "/var/lib/hecate-mpong-bot/data"},

        %% Auto-host loop knobs (defaults from hecate-daemon's
        %% auto_host_demo_loop). The master switch (mpong_auto_host) is
        %% DELIBERATELY absent here: auto_host_enabled/0 only consults the
        %% OS env HECATE_MPONG_AUTO_HOST when the app env is undefined, so
        %% setting it to false here would shadow the OS-env override.
        {mpong_auto_host_interval_ms,    90000},
        {mpong_auto_host_boot_delay_ms,  15000},
        {mpong_auto_host_announce_ms,    10000},
        {mpong_auto_host_bot_count,          2},

        %% Realm STRING used by hecate_topics (this repo's shim) to build
        %% topic strings: io.macula/beam-campus/hecate/mpong/<name>_vN.
        %% This is the topic namespace, NOT the routing tag (see hecate_om).
        {realm, <<"io.macula">>}
    ]},

    %% evoq adapter wiring: dispatch + subscribe + snapshot all go through
    %% reckon_evoq_adapter into the mpong_store reckon-db store. Without this
    %% evoq's event_store is `not_configured` and the store subscription
    %% (hence the whole service) fails to start.
    {evoq, [
        {event_store_adapter,    reckon_evoq_adapter},
        {subscription_adapter,   reckon_evoq_adapter},
        {snapshot_store_adapter, reckon_evoq_adapter}
    ]},

    %% Mesh identity + connection (read by hecate_om_identity). Mirrors the
    %% hecate-parksim pattern — a deployed, working reference.
    %%
    %% - realm: the 32-byte io.macula realm TAG (64 hex) = macula_realm:id(
    %%   <<"io.macula">>). Passed to macula:publish as the routing namespace.
    %% - station_seeds: the Leuven district stations (same set parksim uses;
    %%   they provably route to macula-realm). This is the FALLBACK. To make
    %%   each deployed instance dial a DISTINCT station (one bot per node,
    %%   one station each), set the MACULA_STATION_SEEDS env var (comma-
    %%   separated URLs) — it takes precedence over this list. See the
    %%   Quadlet's EnvironmentFile + quadlet/station.env.example.
    %% - service_cert_path: where the realm-signed service-principal cert is
    %%   mounted in the container. hecate_om LOADS + HOLDS it (service_cert/0)
    %%   for the v2 swap-in; v1 connect/publish does NOT require it — the SDK
    %%   uses an auto-generated peering identity and the mesh does not yet
    %%   verify realm membership. Mint it with scripts/provision-service-cert.sh.
    {hecate_om, [
        {realm, <<"ABB81B5A614B63551B400B810648C0C8A78EFAD845442630C94B46CC95D2FCD1">>},
        {station_seeds, [
            <<"https://station-be-leuven-centrum.macula.io:4433">>,
            <<"https://station-be-leuven-gasthuisberg.macula.io:4433">>,
            <<"https://station-be-leuven-heverlee.macula.io:4433">>,
            <<"https://station-be-leuven-korbeek-lo.macula.io:4433">>
        ]},
        {service_cert_path, "/etc/hecate/secrets/service-cert.pem"}
    ]},

    {kernel, [
        {logger_level, info},
        %% Bound log-term formatting (reckon-db Ra reports can be multi-MB).
        {logger, [
            {handler, default, logger_std_h,
                #{formatter => {logger_formatter,
                    #{depth => 30, chars_limit => 8192}}}}
        ]}
    ]}
].
