{erl_opts, [debug_info]}.

%% Phase 1 spectator read API: list / get / stream / champion. The
%% poll_mpong_game (always-404 — engine_state never populated) and
%% discover_mpong_lobbies (LAN lobby UX, Phase 2) slices were dropped.
{src_dirs, [
    "src",
    "src/list_mpong_games",
    "src/get_mpong_game",
    "src/stream_mpong_game",
    "src/get_champion"
]}.

{shell, [{apps, [query_mpong_games]}]}.
