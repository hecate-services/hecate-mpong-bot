%% -*- mode: erlang -*-
%% rebar3 configuration for hecate-mpong-bot (realm service daemon).
%%
%% Scaffold only — `apps/` is empty until the game-lifecycle slices
%% are extracted from hecate-daemon's `guide_mpong_game_lifecycle`.
%% Once those land, add each as an umbrella app under `apps/` and
%% wire it into the `relx` `applications` list below.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% Service substrate — provides info/health/capability-advertise
    %% scaffolding and the cowboy /health handler.
    {hecate_om, {git, "https://codeberg.org/hecate-services/hecate-om.git", {branch, "main"}}},

    %% Local HTTP (admin / health)
    {cowboy, "~> 2.12.0"}

    %% Future deps (uncomment as slices land):
    %% {reckon_db,    "~> 2.3"},
    %% {evoq,         "~> 1.15"},
    %% {reckon_evoq,  "~> 2.1"},
    %% {reckon_gater, "~> 2.1"},
    %% {esqlite,      "~> 0.8.0"}
]}.

{relx, [
    {release, {hecate_mpong_bot, "0.1.0"}, [
        hecate_mpong_bot,
        hecate_om,
        guide_mpong_game_lifecycle
        %% More slice apps land here as they're extracted:
        %%   run_game_engine, mpong_lobby_seeker, handle_paddle_input,
        %%   host_mpong_game (provides maybe_host_game + host_game_v1),
        %%   request_seat, reserve_seat, deny_seat, ...
        %%
        %% auto_host_demo_loop's host_one_match path depends on
        %% several of these — it will crash with `undef' at runtime
        %% until they land. The advertise + broadcast slices are
        %% pure publishers and would also need `hecate_mesh' and
        %% `hecate_topics' shims (TODO) to publish anywhere.
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [hecate_mpong_bot]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.
