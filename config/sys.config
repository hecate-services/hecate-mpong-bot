[
    {hecate_mpong_bot, [
        {http_port, 8470},
        {data_dir,  "/var/lib/hecate-mpong-bot/data"},

        %% Auto-host loop knobs (extracted defaults from
        %% hecate-daemon's auto_host_demo_loop). All overridable via
        %% the OS env when the slices land:
        %%   {mpong_auto_host, false},                 %% master switch
        %%   {mpong_auto_host_interval_ms,    90_000}, %% match cadence
        %%   {mpong_auto_host_boot_delay_ms,  15_000}, %% wait for mesh
        %%   {mpong_auto_host_announce_ms,    10_000}, %% advertise heartbeat
        %%   {mpong_auto_host_bot_count,           2}  %% paddles per match

        %% Realm we publish under. Used by the slice apps to build
        %% topic strings via hecate_topics:realm_fact/3 et al.
        {realm, <<"io.macula">>}
    ]},

    {hecate_om, [
        {service_cert_path, "/etc/hecate/secrets/service-cert.pem"},
        {station_socket,    "/run/macula/station.sock"},
        {health_port,       8470}
    ]}
].
