# Per-node station selection for hecate-mpong-bot.
#
# Copy to the node's secrets dir as station.env so the Quadlet's
# `EnvironmentFile=-/etc/hecate/secrets/hecate-mpong-bot/station.env`
# picks it up:
#
#   install -m 0644 station.env \
#     /etc/hecate/secrets/hecate-mpong-bot/station.env
#
# MACULA_STATION_SEEDS is a comma-separated list of station URLs. Set it
# to a SINGLE station so each bot enters the mesh through a distinct one.
# It overrides the sys.config fallback seed set (hecate_om reads the env
# var first; see hecate_om_identity:configured_seeds/0).
#
# Requirement: each mpong-bot must connect to a different station. The
# four Leuven district stations below are the bot's proven realm-routing
# set — assign one per node:
#
#   beam00 → centrum         station-be-leuven-centrum.macula.io
#   beam01 → gasthuisberg    station-be-leuven-gasthuisberg.macula.io
#   beam02 → heverlee        station-be-leuven-heverlee.macula.io
#   beam03 → korbeek-lo      station-be-leuven-korbeek-lo.macula.io
#
# This file is the beam00 example. Change the host per node.

MACULA_STATION_SEEDS=https://station-be-leuven-centrum.macula.io:4433
