{erl_opts, [debug_info]}.

%% VERTICAL SLICING: each kept desk directory is an explicit src_dir.
%% Phase 1 (self-hosting bot): host/join/start/end + engine + champion +
%% advertise/broadcast + auto-host. The seat-negotiation / federated-join
%% slices (leave_game, eliminate_player, listen_game_state,
%% handle_paddle_input, open_lobby, seek_lobby) are deferred to Phase 2.
{src_dirs, [
    "src",
    "src/host_game",
    "src/join_game",
    "src/start_game",
    "src/end_game",
    "src/run_game_engine",
    "src/broadcast_game_state",
    "src/advertise_game",
    "src/register_champion",
    "src/auto_host_demo_loop"
]}.

{shell, [{apps, [guide_mpong_game_lifecycle]}]}.
