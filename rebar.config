%% -*- mode: erlang -*-
%% rebar3 configuration for hecate-mpong-bot (realm service daemon).
%%
%% Phase 1 (self-hosting bot): the mpong game lifecycle (CMD/PRJ/QRY)
%% has been extracted from hecate-daemon. The bot event-sources games
%% (reckon_db + evoq), runs the engine with AI paddles, and publishes
%% the byte-identical mpong/game_advertised_v1 + mpong/state_broadcast_v1
%% facts the macula-realm /demo/mpong spectator consumes. The
%% federated seat-negotiation path is deferred to Phase 2.
%%
%% reckon/evoq versions pinned to match hecate-daemon (the code was
%% built against them): reckon_db 2.0.0 / reckon_gater ~> 2.3 /
%% evoq 1.14.4 / reckon_evoq 2.0.0.

%% No warnings_as_errors: the moved daemon code wasn't built with it.
{erl_opts, [debug_info]}.

{deps, [
    %% Service substrate — info/health/capability-advertise + the
    %% macula client pool the mesh publisher uses.
    {hecate_om, {git, "https://codeberg.org/hecate-services/hecate-om.git", {branch, "main"}}},

    %% Local HTTP (admin / health + the QRY spectator read API).
    {cowboy, "~> 2.12.0"},

    %% Event sourcing — game lifecycle store + CQRS adapter.
    {reckon_db,    "2.0.0"},
    {reckon_gater, "~> 2.3"},
    {evoq,         "1.14.4"},
    {reckon_evoq,  "2.0.0"}
]}.

{relx, [
    {release, {hecate_mpong_bot, "0.1.0"}, [
        hecate_mpong_bot,
        hecate_om,
        guide_mpong_game_lifecycle,
        project_mpong_games,
        query_mpong_games
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [hecate_mpong_bot]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.
